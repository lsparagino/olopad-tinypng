{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TinyPNG Compressor",
  "version": "0.9.1",
  "identifier": "com.tinypng.compressor",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "TinyPNG Compressor",
        "width": 520,
        "height": 680,
        "resizable": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
